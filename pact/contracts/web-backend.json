{
  "consumer": { "name": "ownpulse-web" },
  "provider": { "name": "ownpulse-api" },
  "interactions": [
    {
      "description": "a request to list sleep records",
      "providerState": "sleep records exist",
      "request": {
        "method": "GET",
        "path": "/api/v1/sleep",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "uuid-1",
            "user_id": "user-1",
            "date": "2026-03-10",
            "sleep_start": "2026-03-09T23:00:00Z",
            "sleep_end": "2026-03-10T07:00:00Z",
            "duration_minutes": 480,
            "deep_minutes": 90,
            "light_minutes": 210,
            "rem_minutes": 120,
            "awake_minutes": 60,
            "score": 82,
            "source": "manual",
            "source_id": null,
            "notes": null,
            "created_at": "2026-03-10T08:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to list auth methods",
      "request": {
        "method": "GET",
        "path": "/api/v1/auth/methods",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "uuid-1",
            "provider": "local",
            "email": "user@example.com",
            "created_at": "2026-03-10T08:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to authenticate via Apple Sign-In callback from web",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/apple/callback",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "id_token": "some-apple-id-token",
          "platform": "web"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "description": "a request to link Apple as an auth provider",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/link",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "provider": "apple",
          "id_token": "some-apple-id-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "uuid-1",
            "provider": "apple",
            "email": "user@privaterelay.appleid.com",
            "created_at": "2026-03-10T08:00:00Z"
          },
          {
            "id": "uuid-2",
            "provider": "local",
            "email": "user@example.com",
            "created_at": "2026-03-10T08:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to register a new account",
      "providerState": "a valid invite code VALID-INVITE exists",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/register",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "newuser@example.com",
          "password": "securepassword",
          "invite_code": "VALID-INVITE"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "description": "a request to register with an invalid invite code",
      "providerState": "no matching invite code exists",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/register",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "newuser@example.com",
          "password": "securepassword",
          "invite_code": "INVALID"
        }
      },
      "response": {
        "status": 400,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "error": "Invalid invite code"
        }
      }
    },
    {
      "description": "a request to register with a duplicate email",
      "providerState": "a user with email exists",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/register",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "existing@example.com",
          "password": "securepassword",
          "invite_code": "VALID-INVITE"
        }
      },
      "response": {
        "status": 409,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "error": "Email already registered"
        }
      }
    },
    {
      "description": "a request to list available explore metrics",
      "request": {
        "method": "GET",
        "path": "/api/v1/explore/metrics",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "sources": [
            {
              "source": "checkins",
              "label": "Check-ins",
              "metrics": [
                { "field": "energy", "label": "Energy", "unit": "score" }
              ]
            }
          ]
        }
      }
    },
    {
      "description": "a request to fetch batch series data",
      "request": {
        "method": "POST",
        "path": "/api/v1/explore/series",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "metrics": [{ "source": "checkins", "field": "energy" }],
          "start": "2026-03-01",
          "end": "2026-03-07",
          "resolution": "daily"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "series": [
            {
              "source": "checkins",
              "field": "energy",
              "unit": "score",
              "points": [
                { "t": "2026-03-01T00:00:00Z", "v": 7, "n": 1 }
              ]
            }
          ]
        }
      }
    },
    {
      "description": "a request to list saved charts",
      "request": {
        "method": "GET",
        "path": "/api/v1/explore/charts",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "uuid-1",
            "name": "My Chart",
            "config": {
              "version": 1,
              "metrics": [{ "source": "checkins", "field": "energy" }],
              "range": { "preset": "30d" },
              "resolution": "daily"
            },
            "created_at": "2026-03-10T08:00:00Z",
            "updated_at": "2026-03-10T08:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to create a saved chart",
      "request": {
        "method": "POST",
        "path": "/api/v1/explore/charts",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "name": "My Chart",
          "config": {
            "version": 1,
            "metrics": [{ "source": "checkins", "field": "energy" }],
            "range": { "preset": "30d" },
            "resolution": "daily"
          }
        }
      },
      "response": {
        "status": 201,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "id": "uuid-1",
          "name": "My Chart",
          "config": {
            "version": 1,
            "metrics": [{ "source": "checkins", "field": "energy" }],
            "range": { "preset": "30d" },
            "resolution": "daily"
          },
          "created_at": "2026-03-10T08:00:00Z",
          "updated_at": "2026-03-10T08:00:00Z"
        }
      }
    },
    {
      "description": "a request to delete a saved chart",
      "request": {
        "method": "DELETE",
        "path": "/api/v1/explore/charts/uuid-1",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 204
      }
    },
    {
      "description": "a request to unlink an auth provider",
      "request": {
        "method": "DELETE",
        "path": "/api/v1/auth/link/google",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "uuid-1",
            "provider": "local",
            "email": "user@example.com",
            "created_at": "2026-03-10T08:00:00Z"
          }
        ]
      }
    }
  ],
  "metadata": { "pactSpecification": { "version": "2.0.0" } }
}
