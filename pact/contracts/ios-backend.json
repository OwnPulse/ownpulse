{
  "consumer": { "name": "ownpulse-ios" },
  "provider": { "name": "ownpulse-api" },
  "interactions": [
    {
      "description": "a request to refresh auth token via JSON body",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/refresh",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "refresh_token": "some-refresh-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "description": "a request to bulk sync HealthKit records",
      "request": {
        "method": "POST",
        "path": "/api/v1/healthkit/sync",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "records": [
            {
              "source": "healthkit",
              "record_type": "heart_rate",
              "value": 72.0,
              "unit": "bpm",
              "start_time": "2026-03-20T10:00:00Z",
              "end_time": "2026-03-20T10:00:00Z"
            }
          ]
        }
      },
      "response": {
        "status": 201,
        "headers": {
          "Content-Type": "application/json"
        }
      }
    },
    {
      "description": "a request to get the HealthKit write-back queue",
      "request": {
        "method": "GET",
        "path": "/api/v1/healthkit/write-queue",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": []
      }
    },
    {
      "description": "a request to confirm HealthKit write-back items",
      "request": {
        "method": "POST",
        "path": "/api/v1/healthkit/confirm",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "ids": []
        }
      },
      "response": {
        "status": 204
      }
    },
    {
      "description": "a request to authenticate via Apple Sign-In callback",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/apple/callback",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "id_token": "some-apple-id-token",
          "platform": "ios"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "refresh_token": "some-refresh-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "description": "a request to list linked auth methods",
      "request": {
        "method": "GET",
        "path": "/api/v1/auth/methods",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "some-uuid",
            "provider": "apple",
            "email": "user@example.com",
            "created_at": "2026-03-20T10:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to link a new auth provider",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/link",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "provider": "local",
          "password": "securepassword123"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "some-uuid",
            "provider": "local",
            "email": null,
            "created_at": "2026-03-20T10:00:00Z"
          }
        ]
      }
    },
    {
      "description": "a request to unlink an auth provider",
      "request": {
        "method": "DELETE",
        "path": "/api/v1/auth/link/google",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": [
          {
            "id": "some-uuid",
            "provider": "apple",
            "email": "user@example.com",
            "created_at": "2026-03-20T10:00:00Z"
          }
        ]
      }
    }
  ],
  "metadata": { "pactSpecification": { "version": "2.0.0" } }
}
