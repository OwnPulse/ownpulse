      "description": "a request to refresh auth token via JSON body",
      "providerState": "an authenticated user exists",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/refresh",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "refresh_token": "some-refresh-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
