{
  "consumer": { "name": "ownpulse-ios" },
  "provider": { "name": "ownpulse-api" },
  "interactions": [
    {
      "description": "a request to refresh auth token via JSON body",
      "request": {
        "method": "POST",
        "path": "/api/v1/auth/refresh",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "refresh_token": "some-refresh-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "access_token": "some-jwt-token",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "description": "a request to bulk sync HealthKit records",
      "request": {
        "method": "POST",
        "path": "/api/v1/healthkit/sync",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "records": [
            {
              "source": "healthkit",
              "record_type": "heart_rate",
              "value": 72.0,
              "unit": "bpm",
              "start_time": "2026-03-20T10:00:00Z",
              "end_time": "2026-03-20T10:00:00Z"
            }
          ]
        }
      },
      "response": {
        "status": 201,
        "headers": {
          "Content-Type": "application/json"
        }
      }
    },
    {
      "description": "a request to get the HealthKit write-back queue",
      "request": {
        "method": "GET",
        "path": "/api/v1/healthkit/write-queue",
        "headers": {
          "Authorization": "Bearer some-jwt-token"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": []
      }
    },
    {
      "description": "a request to confirm HealthKit write-back items",
      "request": {
        "method": "POST",
        "path": "/api/v1/healthkit/confirm",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "ids": []
        }
      },
      "response": {
        "status": 204
      }
    },
    {
      "description": "a request to create a sleep record from HealthKit",
      "request": {
        "method": "POST",
        "path": "/api/v1/sleep",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "date": "2026-03-19",
          "sleep_start": "2026-03-19T22:00:00Z",
          "sleep_end": "2026-03-20T06:00:00Z",
          "duration_minutes": 480,
          "deep_minutes": 90,
          "light_minutes": 240,
          "rem_minutes": 120,
          "awake_minutes": 30,
          "score": null,
          "source": "healthkit",
          "source_id": "com.apple.health",
          "notes": null
        }
      },
      "response": {
        "status": 201,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "id": "some-uuid",
          "user_id": "some-user-uuid",
          "date": "2026-03-19",
          "sleep_start": "2026-03-19T22:00:00Z",
          "sleep_end": "2026-03-20T06:00:00Z",
          "duration_minutes": 480,
          "deep_minutes": 90,
          "light_minutes": 240,
          "rem_minutes": 120,
          "awake_minutes": 30,
          "score": null,
          "source": "healthkit",
          "source_id": "com.apple.health",
          "notes": null,
          "created_at": "2026-03-20T00:00:00Z"
        }
      }
    },
    {
      "description": "a request to create a duplicate sleep record returns 409",
      "request": {
        "method": "POST",
        "path": "/api/v1/sleep",
        "headers": {
          "Authorization": "Bearer some-jwt-token",
          "Content-Type": "application/json"
        },
        "body": {
          "date": "2026-03-19",
          "sleep_start": "2026-03-19T22:00:00Z",
          "sleep_end": "2026-03-20T06:00:00Z",
          "duration_minutes": 480,
          "deep_minutes": 90,
          "light_minutes": 240,
          "rem_minutes": 120,
          "awake_minutes": 30,
          "score": null,
          "source": "healthkit",
          "source_id": "com.apple.health",
          "notes": null
        }
      },
      "response": {
        "status": 409
      }
    }
  ],
  "metadata": { "pactSpecification": { "version": "2.0.0" } }
}
