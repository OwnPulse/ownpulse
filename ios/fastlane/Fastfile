default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do |options|
    scheme = options[:scheme] || "OwnPulse"
    configuration = options[:configuration] || "Release"
    app_id = options[:app_identifier] || "health.ownpulse.app"

    key_content = if ENV["ASC_KEY_PATH"]
      File.read(ENV["ASC_KEY_PATH"])
    elsif ENV["ASC_KEY_CONTENT"]
      ENV["ASC_KEY_CONTENT"]
    else
      raise "Set ASC_KEY_PATH or ASC_KEY_CONTENT"
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: key_content,
    )

    match(
      type: "appstore",
      app_identifier: app_id,
      readonly: true,
      api_key: api_key,
    )

    current_build = latest_testflight_build_number(
      app_identifier: app_id,
      api_key: api_key,
    )

    build_number = current_build + 1

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "OwnPulse.xcodeproj",
      team_id: "J7C37BSM3L",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{app_id}",
      bundle_identifier: app_id,
      targets: ["OwnPulse"],
    )

    build_app(
      scheme: scheme,
      configuration: configuration,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_id => "match AppStore #{app_id}",
        },
      },
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_id,
      skip_waiting_for_build_processing: true,
    )
  end
end
