# Stage 1: Build
FROM rust:1.83-slim-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY api/Cargo.toml api/Cargo.toml

# Create dummy main to cache dependency build
RUN mkdir -p api/src && echo "fn main() {}" > api/src/main.rs
RUN cargo build --release --locked && rm -rf api/src

# Copy real source and rebuild.
# .sqlx/ holds the sqlx offline query cache (query-*.json files generated by
# `cargo sqlx prepare --workspace`).  It must exist in the build context even
# when empty — the directory is committed to the repo via .sqlx/.gitkeep so
# that COPY never fails.  SQLX_OFFLINE=true tells the sqlx macros to use the
# cache instead of connecting to a database at compile time.
COPY api/ api/
COPY .sqlx/ .sqlx/
ENV SQLX_OFFLINE=true
RUN touch api/src/main.rs && cargo build --release --locked

# Stage 2: Runtime
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libssl3 \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 app && useradd --uid 1000 --gid app --shell /bin/false app

COPY --from=builder /app/target/release/api /usr/local/bin/api

USER app
EXPOSE 8080
ENTRYPOINT ["api"]
