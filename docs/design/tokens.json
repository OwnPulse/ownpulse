      "error-light": { "value": "#f5dede" }
    }
  },
  "typography": {
    "font-family": {
      "display": { "value": "\"Source Serif 4\", Georgia, \"Times New Roman\", serif" },
      "body": { "value": "\"IBM Plex Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif" },
      "mono": { "value": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, monospace" }
    },
    "font-size": {
      "xs": { "value": "0.75rem" },
      "sm": { "value": "0.875rem" },
      "base": { "value": "1rem" },
      "lg": { "value": "1.125rem" },
      "xl": { "value": "1.25rem" },
      "2xl": { "value": "1.5rem" },
      "3xl": { "value": "2rem" },
      "4xl": { "value": "2.75rem" }
    }
  },
  "spacing": {
    "content-padding": { "value": "1.5rem" },
    "sidebar-width": { "value": "220px" },
    "content-max-width": { "value": "72rem" }
