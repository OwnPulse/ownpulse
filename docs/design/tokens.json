{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "OwnPulse Design Tokens",
    "description": "Canonical, versioned source of truth for OwnPulse design tokens. Migrated verbatim from web/src/styles/variables.css. The chart.metric color slots feed the downstream Style Dictionary pipeline and chart-color unit (B5).",
    "version": "1.0.0",
    "source": "web/src/styles/variables.css",
    "chartMetricColors": "Per-metric chart color slots under chart.metric. heart_rate, hrv, and weight reuse exact values from the existing palette (web/src/styles/variables.css), and the fallback cycle reuses web/src/components/explore/chartColors.ts (lowercased). sleep_duration, glucose, bp_systolic, and bp_diastolic are newly assigned from existing palette colors and the colorblind-safe Wong palette to give each metric a distinct, accessible hue. bp_systolic deliberately avoids the brand-primary hue (#c2654a) so chart series do not collide with brand-colored UI chrome."
  },
  "color": {
    "primary": {
      "default": { "value": "#b2573c" },
      "hover": { "value": "#9e4f38" },
      "light": { "value": "#f7eeec" }
    },
    "accent": {
      "default": { "value": "#377c7c" },
      "light": { "value": "#5aadad" },
      "dark": { "value": "#2d6b6b" }
    },
    "dimension": {
      "gold": { "value": "#c49a3c" },
      "sage": { "value": "#5a8a5a" },
      "purple": { "value": "#7b61c2" }
    },
    "neutral": {
