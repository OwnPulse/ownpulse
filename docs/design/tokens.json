      "800": { "value": "#2d2d2a" },
      "700": { "value": "#44443f" },
      "600": { "value": "#5e5e57" },
      "500": { "value": "#7a7a72" },
      "400": { "value": "#9c9c93" },
      "300": { "value": "#c2c2b9" },
      "200": { "value": "#deded6" },
      "100": { "value": "#eeeeea" },
      "50": { "value": "#f7f7f4" }
    },
    "surface": {
      "bg": { "value": "#fafaf7" },
      "bg-warm": { "value": "#faf6f1" },
      "default": { "value": "#fafaf7" },
      "elevated": { "value": "#ffffff" }
    },
    "text": {
      "default": { "value": "#1e1e1c" },
      "secondary": { "value": "#5e5e57" },
